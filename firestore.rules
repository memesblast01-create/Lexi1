rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'plan', 'usageCount', 'createdAt']) 
             && data.uid == request.auth.uid
             && data.email is string
             && data.plan in ['free', 'standard', 'premium']
             && data.usageCount is number
             && (!data.keys().contains('displayName') || data.displayName is string);
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      // Allow user updates to name, email, usageCount, and plan
      allow update: if isOwner(userId) 
                    && incoming().diff(existing()).affectedKeys().hasOnly(['usageCount', 'plan', 'displayName', 'email'])
                    && (!incoming().keys().contains('displayName') || incoming().displayName is string)
                    && (!incoming().keys().contains('email') || incoming().email is string)
                    && incoming().usageCount >= existing().usageCount;
    }

    // --- Analysis Validation ---
    function isValidAnalysis(data) {
      return data.keys().hasAll(['userId', 'docName', 'docType', 'result', 'createdAt'])
             && data.keys().size() == 5
             && data.userId == request.auth.uid
             && data.docName is string && data.docName.size() <= 256
             && data.docType is string
             && data.result is map
             && data.createdAt == request.time;
    }

    match /users/{userId}/analyses/{analysisId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidAnalysis(incoming()) && isValidId(analysisId);
      allow delete: if isOwner(userId);
    }
  }
}
